# ServoBox project configuration.
# Copy this file to .servobox/config with:
#   servobox config init
#
# Values here are Bash assignments. They are project defaults only:
# explicit CLI flags still override this file.

# VM identity and sizing.
SERVOBOX_NAME="servobox-vm"
SERVOBOX_VCPUS=4
SERVOBOX_MEMORY=8192
SERVOBOX_DISK_GB=20

# RT tuning mode: balanced, performance, or extreme.
SERVOBOX_RT_MODE="balanced"

# Networking.
# Leave SERVOBOX_BRIDGE empty to use libvirt NAT.
SERVOBOX_BRIDGE=""
SERVOBOX_IP="192.168.122.100/24"

# Optional direct NIC passthrough for robot/device networks.
# Examples:
#   SERVOBOX_HOST_NICS=("eno1")
#   SERVOBOX_HOST_NICS=("eno1" "eno2")
SERVOBOX_HOST_NICS=()
SERVOBOX_CHOOSE_NIC=0

# Optional image and SSH key overrides. Relative paths resolve from the project root.
SERVOBOX_IMAGE=""
SERVOBOX_SSH_PUBKEY=""
SERVOBOX_SSH_KEY=""

# Package install defaults.
# SERVOBOX_PKG_INSTALL may be a recipe name, a config name from the active
# recipe channel, or a relative/absolute config file path.
SERVOBOX_PKG_INSTALL=""

# Optional custom recipe directory or config file.
# Common project-local layouts:
#   SERVOBOX_PKG_CUSTOM=".servobox/recipes"
#   SERVOBOX_PKG_CUSTOM=".servobox/packages.conf"
SERVOBOX_PKG_CUSTOM=""

# Run defaults.
# Bare `servobox run` first tries .servobox/run.sh. If no project run script is
# present, SERVOBOX_RUN_PACKAGE can point to a recipe that has run.sh.
SERVOBOX_RUN_PACKAGE=""
SERVOBOX_RUN_SCRIPT=""
